<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{PRODUCT_NAME}}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '{{PRIMARY_COLOR}}',
            accent: '{{ACCENT_COLOR}}'
          }
        }
      }
    }
  </script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-white text-accent">
  <!-- Hero -->
  <section class="min-h-[70vh] flex flex-col items-center justify-center text-center px-6 py-20">
    <div class="max-w-3xl">
      <div class="mb-8" id="logo-slot">
        <!-- Logo inserted here by logo-generate if available -->
      </div>
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-6">{{PRODUCT_NAME}}</h1>
      <p class="text-xl md:text-2xl text-gray-600 mb-10">{{TAGLINE}}</p>
      <p class="text-lg text-gray-500 mb-10 max-w-2xl mx-auto">{{DESCRIPTION}}</p>
      {{CTA_BLOCK}}
    </div>
  </section>

  <!-- Features -->
  <section class="bg-gray-50 py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12">Features</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {{FEATURES_BLOCK}}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 px-6 text-center text-gray-400 text-sm">
    <p>&copy; {{COPYRIGHT}}</p>
  </footer>
</body>
</html>
