#!/usr/bin/env bash
# brand-generate v5.1 — Gemini creates on light bg + Recraft post-processes + alpha-aware trim
#
# Key insights:
#   - Generate logos/features/UI shots on WHITE backgrounds (high contrast for bg removal)
#   - Remove bg FIRST, then vectorize the transparent result (no bg paths in SVG)
#   - Pass logo as input image to mockup prompt for brand consistency
#   - Alpha-aware trim for transparent PNGs (scans RGBA pixels for bounding box)
#
# Usage: brand-generate <config.json> [output_dir]
# Requires: RECRAFT_API_KEY and GEMINI_API_KEY environment variables
set -euo pipefail

[[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && {
  echo "Usage: brand-generate <config.json> [output_dir]"
  echo ""
  echo "Generates logo (SVG+PNG), feature illustrations, UI shots (all transparent),"
  echo "hero background, product mockup, and OG card."
  echo ""
  echo "Requires: RECRAFT_API_KEY and GEMINI_API_KEY"
  exit 0
}

if [[ $# -lt 1 ]]; then
  echo "Usage: brand-generate <config.json> [output_dir]" >&2
  exit 1
fi

CONFIG_JSON="$1"
OUTPUT_DIR="${2:-.}"

if [[ ! -f "$CONFIG_JSON" ]]; then
  echo "ERROR: Config file not found: $CONFIG_JSON" >&2
  exit 1
fi

for var in RECRAFT_API_KEY GEMINI_API_KEY; do
  if [[ -z "${!var:-}" ]]; then
    echo "ERROR: $var environment variable is not set" >&2
    exit 1
  fi
done

mkdir -p "$OUTPUT_DIR"

# --- Config extraction -------------------------------------------------------

extract() {
  node -e "
    const cfg = JSON.parse(require('fs').readFileSync('$CONFIG_JSON', 'utf8'));
    const path = '$1'.split('.');
    let val = cfg;
    for (const p of path) {
      if (val == null) { process.stdout.write(''); process.exit(0); }
      val = val[p];
    }
    if (Array.isArray(val)) process.stdout.write(val.join('; '));
    else process.stdout.write(String(val ?? ''));
  "
}

PRODUCT_NAME="$(extract 'product_name')"
DESCRIPTION="$(extract 'meta_description')"
PRIMARY_COLOR="$(extract 'brand.primary')"
SECONDARY_COLOR="$(extract 'brand.secondary')"
ACCENT_COLOR="$(extract 'brand.accent')"
BG_COLOR="$(extract 'brand.dark')"

HERO_HEADLINE="$(node -e "
  const c=JSON.parse(require('fs').readFileSync('$CONFIG_JSON','utf8'));
  process.stdout.write((c.hero?.headline||'').replace(/\{\{gradient:(.*?)\}\}/g,'\$1'));
")"

FEATURES_JSON="$(node -e "
  const c=JSON.parse(require('fs').readFileSync('$CONFIG_JSON','utf8'));
  const items=c.features?.items||c.features||[];
  process.stdout.write(JSON.stringify(items));
")"

FEATURE_COUNT="$(node -e "process.stdout.write(String(JSON.parse(process.argv[1]).length))" "$FEATURES_JSON")"

SOLUTION_BULLETS="$(node -e "
  const c=JSON.parse(require('fs').readFileSync('$CONFIG_JSON','utf8'));
  process.stdout.write(JSON.stringify(c.solution?.bullets||[]));
")"

echo "=== Brand Generate v5.1 (Gemini + Recraft + alpha-aware trim) ==="
echo "Product:   $PRODUCT_NAME"
echo "Headline:  $HERO_HEADLINE"
echo "Colors:    primary=$PRIMARY_COLOR secondary=$SECONDARY_COLOR accent=$ACCENT_COLOR"
echo "Features:  $FEATURE_COUNT items"
echo ""

ERRORS=0

# --- Gemini API --------------------------------------------------------------

GEMINI_URL="https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-image:generateContent?key=${GEMINI_API_KEY}"

generate_gemini() {
  local prompt="$1"
  local output_file="$2"
  local input_image="${3:-}"
  local label
  label="$(basename "$output_file")"
  local tmp_response
  tmp_response="$(mktemp /tmp/gemini-XXXXXX.json)"
  local tmp_payload
  tmp_payload="$(mktemp /tmp/gemini-payload-XXXXXX.json)"

  if [[ -n "$input_image" && -f "$input_image" ]]; then
    node -e "
      const fs = require('fs');
      const imgData = fs.readFileSync(process.argv[2]).toString('base64');
      const mime = process.argv[2].endsWith('.png') ? 'image/png' : 'image/jpeg';
      fs.writeFileSync(process.argv[3], JSON.stringify({
        contents: [{ parts: [
          { text: process.argv[1] },
          { inlineData: { mimeType: mime, data: imgData } }
        ]}],
        generationConfig: { responseModalities: ['TEXT', 'IMAGE'] }
      }));
    " "$prompt" "$input_image" "$tmp_payload"
  else
    node -e "
      const fs = require('fs');
      fs.writeFileSync(process.argv[2], JSON.stringify({
        contents: [{ parts: [{ text: process.argv[1] }] }],
        generationConfig: { responseModalities: ['TEXT', 'IMAGE'] }
      }));
    " "$prompt" "$tmp_payload"
  fi

  local attempt
  for attempt in 1 2 3; do
    echo "  [$label] Gemini — attempt $attempt/3..."
    local http_code
    http_code="$(curl -s -w '%{http_code}' -o "$tmp_response" \
      --max-time 180 \
      -X POST "$GEMINI_URL" \
      -H "Content-Type: application/json" \
      -d "@$tmp_payload")" || true

    if [[ "$http_code" == "200" ]]; then
      if node -e "
        const fs = require('fs');
        const r = JSON.parse(fs.readFileSync('$tmp_response', 'utf8'));
        const parts = r.candidates?.[0]?.content?.parts;
        if (!parts) process.exit(1);
        const img = parts.find(p => p.inlineData?.data);
        if (!img) process.exit(1);
        fs.writeFileSync('$output_file', Buffer.from(img.inlineData.data, 'base64'));
      " 2>/dev/null; then
        echo "  [$label] OK — $(du -h "$output_file" | cut -f1)"
        rm -f "$tmp_response" "$tmp_payload"
        return 0
      else
        echo "  [$label] No image in response"
      fi
    fi
    echo "  [$label] Failed (HTTP $http_code), retrying..."
    sleep 2
  done

  echo "  [$label] ERROR: All 3 attempts failed"
  rm -f "$tmp_response" "$tmp_payload"
  return 1
}

# --- Recraft post-processing -------------------------------------------------

RECRAFT_BASE="https://external.api.recraft.ai/v1"

recraft_remove_bg() {
  local input_file="$1"
  local output_file="$2"
  local label
  label="$(basename "$output_file") bg-remove"
  local tmp_response
  tmp_response="$(mktemp /tmp/recraft-XXXXXX.json)"

  local attempt
  for attempt in 1 2 3; do
    echo "  [$label] — attempt $attempt/3..."
    local http_code
    http_code="$(curl -s -w '%{http_code}' -o "$tmp_response" \
      --max-time 120 \
      -X POST "${RECRAFT_BASE}/images/removeBackground" \
      -H "Authorization: Bearer ${RECRAFT_API_KEY}" \
      -F "file=@$input_file")" || true

    if [[ "$http_code" == "200" ]]; then
      local img_url
      img_url="$(node -e "
        const r = JSON.parse(require('fs').readFileSync('$tmp_response','utf8'));
        if (r.image?.url) process.stdout.write(r.image.url);
      " 2>/dev/null)"
      if [[ -n "$img_url" ]] && curl -s --max-time 60 -o "$output_file" "$img_url"; then
        echo "  [$label] OK — $(du -h "$output_file" | cut -f1)"
        rm -f "$tmp_response"
        return 0
      fi
    fi

    local err
    err="$(node -e "try{const r=JSON.parse(require('fs').readFileSync('$tmp_response','utf8'));process.stdout.write(r.error?.message||r.detail||r.message||JSON.stringify(r).substr(0,200));}catch(e){process.stdout.write('error');}" 2>/dev/null)"
    echo "  [$label] Failed ($http_code): $err"
    sleep 2
  done

  echo "  [$label] ERROR: All 3 attempts failed"
  rm -f "$tmp_response"
  return 1
}

recraft_vectorize() {
  local input_file="$1"
  local output_file="$2"
  local label
  label="$(basename "$output_file") vectorize"
  local tmp_response
  tmp_response="$(mktemp /tmp/recraft-XXXXXX.json)"

  local attempt
  for attempt in 1 2 3; do
    echo "  [$label] — attempt $attempt/3..."
    local http_code
    http_code="$(curl -s -w '%{http_code}' -o "$tmp_response" \
      --max-time 120 \
      -X POST "${RECRAFT_BASE}/images/vectorize" \
      -H "Authorization: Bearer ${RECRAFT_API_KEY}" \
      -F "file=@$input_file")" || true

    if [[ "$http_code" == "200" ]]; then
      local img_url
      img_url="$(node -e "
        const r = JSON.parse(require('fs').readFileSync('$tmp_response','utf8'));
        if (r.image?.url) process.stdout.write(r.image.url);
      " 2>/dev/null)"
      if [[ -n "$img_url" ]] && curl -s --max-time 60 -o "$output_file" "$img_url"; then
        echo "  [$label] OK — $(du -h "$output_file" | cut -f1)"
        rm -f "$tmp_response"
        return 0
      fi
    fi

    local err
    err="$(node -e "try{const r=JSON.parse(require('fs').readFileSync('$tmp_response','utf8'));process.stdout.write(r.error?.message||r.detail||r.message||JSON.stringify(r).substr(0,200));}catch(e){process.stdout.write('error');}" 2>/dev/null)"
    echo "  [$label] Failed ($http_code): $err"
    sleep 2
  done

  echo "  [$label] ERROR: All 3 attempts failed"
  rm -f "$tmp_response"
  return 1
}

# --- Alpha-aware auto-trim + convert to PNG -----------------------------------

# trim_alpha <file> [threshold]
# Scans RGBA pixels to find alpha bounding box, crops to content.
# threshold: minimum alpha value to consider as content (default 10)
trim_alpha() {
  local file="$1"
  local threshold="${2:-10}"

  if [[ ! -f "$file" ]]; then return 1; fi

  NODE_PATH=/app/node_modules node -e "
    const sharp = require('sharp');
    const fs = require('fs');

    (async () => {
      const meta = await sharp(process.argv[1]).metadata();
      if (!meta.hasAlpha) {
        // No alpha — use standard trim
        const trimmed = await sharp(process.argv[1]).trim({threshold: parseInt(process.argv[2])}).png().toBuffer();
        const tm = await sharp(trimmed).metadata();
        fs.writeFileSync(process.argv[1], trimmed);
        var saved = Math.round((1 - (tm.width * tm.height) / (meta.width * meta.height)) * 100);
        console.log('  [trim] ' + meta.width + 'x' + meta.height + ' -> ' + tm.width + 'x' + tm.height + ' (' + saved + '% trimmed)');
        return;
      }

      const { data, info } = await sharp(process.argv[1]).raw().toBuffer({ resolveWithObject: true });
      const ch = info.channels;
      const thresh = parseInt(process.argv[2]) || 10;
      var minX = info.width, minY = info.height, maxX = 0, maxY = 0;

      for (var y = 0; y < info.height; y++) {
        for (var x = 0; x < info.width; x++) {
          var idx = (y * info.width + x) * ch;
          var alpha = data[idx + (ch - 1)];
          if (alpha > thresh) {
            if (x < minX) minX = x;
            if (x > maxX) maxX = x;
            if (y < minY) minY = y;
            if (y > maxY) maxY = y;
          }
        }
      }

      if (maxX < minX || maxY < minY) {
        console.log('  [trim] no visible pixels found');
        return;
      }

      var w = maxX - minX + 1;
      var h = maxY - minY + 1;
      var cropped = await sharp(process.argv[1])
        .extract({ left: minX, top: minY, width: w, height: h })
        .png().toBuffer();
      fs.writeFileSync(process.argv[1], cropped);

      var saved = Math.round((1 - (w * h) / (meta.width * meta.height)) * 100);
      console.log('  [trim] ' + meta.width + 'x' + meta.height + ' -> ' + w + 'x' + h + ' (' + saved + '% trimmed)');
    })().catch(function(e) { console.error('  [trim] error: ' + e.message); process.exit(1); });
  " "$file" "$threshold" || echo "  [trim] failed"
}

# =============================================================================
# STEP 1: Logo (icon + wordmark) on WHITE bg → remove bg → trim → vectorize
# =============================================================================

echo "--- Step 1a: Generate logo with wordmark (Gemini, white bg) ---"

LOGO_RAW="$OUTPUT_DIR/.logo-raw.png"

LOGO_PROMPT="Design a modern tech company logo for \"${PRODUCT_NAME}\".

Layout: horizontal — a minimal geometric icon mark on the left, the word \"${PRODUCT_NAME}\" in clean modern sans-serif font on the right. The icon and text should be the same height.

Brand: ${DESCRIPTION}
Colors: Use ${PRIMARY_COLOR} and ${SECONDARY_COLOR} for the icon. The text should be dark charcoal (#1E293B).
Background: Pure white (#FFFFFF).

Style: Professional SaaS logo like Stripe, Linear, or Vercel. The icon should be a single abstract geometric shape — no literal illustrations, no letters inside the icon. Simple enough to work at 32px.

IMPORTANT: The background MUST be pure solid white. No gradients, no patterns, no dark areas. White everywhere except the logo itself."

generate_gemini "$LOGO_PROMPT" "$LOGO_RAW" || ((ERRORS++))

if [[ -f "$LOGO_RAW" ]]; then
  echo ""
  echo "--- Step 1b: Remove background → transparent PNG ---"
  recraft_remove_bg "$LOGO_RAW" "$OUTPUT_DIR/logo.png" || ((ERRORS++))

  if [[ -f "$OUTPUT_DIR/logo.png" ]]; then
    echo "--- Step 1b.1: Trim logo ---"
    trim_alpha "$OUTPUT_DIR/logo.png" 3

    echo ""
    echo "--- Step 1c: Vectorize trimmed PNG → SVG ---"
    # Recraft vectorize requires min 256px on each dimension — upscale if needed
    VECTORIZE_SRC="$OUTPUT_DIR/logo.png"
    logo_min_dim="$(NODE_PATH=/app/node_modules node -e "
      const sharp = require('sharp');
      sharp(process.argv[1]).metadata().then(m => process.stdout.write(String(Math.min(m.width, m.height))));
    " "$OUTPUT_DIR/logo.png" 2>/dev/null)"
    if [[ -n "$logo_min_dim" && "$logo_min_dim" -lt 256 ]]; then
      echo "  Logo min dimension ${logo_min_dim}px < 256 — upscaling for vectorization"
      VECTORIZE_SRC="$OUTPUT_DIR/.logo-upscaled.png"
      NODE_PATH=/app/node_modules node -e "
        const sharp = require('sharp');
        const fs = require('fs');
        (async () => {
          const meta = await sharp(process.argv[1]).metadata();
          const scale = Math.ceil(256 / Math.min(meta.width, meta.height));
          const buf = await sharp(process.argv[1])
            .resize(meta.width * scale, meta.height * scale, { kernel: 'lanczos3' })
            .png().toBuffer();
          fs.writeFileSync(process.argv[2], buf);
          const m2 = await sharp(buf).metadata();
          console.log('  Upscaled to ' + m2.width + 'x' + m2.height);
        })();
      " "$OUTPUT_DIR/logo.png" "$VECTORIZE_SRC" 2>/dev/null
    fi
    recraft_vectorize "$VECTORIZE_SRC" "$OUTPUT_DIR/logo.svg" || ((ERRORS++))
    rm -f "$OUTPUT_DIR/.logo-upscaled.png"
  fi
fi

# Generate dark-bg logo variant (white text, same icon) via pixel recoloring
echo ""
echo "--- Step 1d: Generate logo dark variant (programmatic recolor) ---"

if [[ -f "$OUTPUT_DIR/logo.png" ]]; then
  NODE_PATH=/app/node_modules node -e "
    const sharp = require('sharp');
    const fs = require('fs');

    (async () => {
      const inputFile = process.argv[1];
      const outputFile = process.argv[2];

      const { data, info } = await sharp(inputFile).raw().toBuffer({ resolveWithObject: true });
      const pixels = Buffer.from(data);
      const ch = info.channels;

      for (var i = 0; i < pixels.length; i += ch) {
        var r = pixels[i], g = pixels[i+1], b = pixels[i+2], a = pixels[i+3];
        if (a < 5) continue;

        var lum = r * 0.299 + g * 0.587 + b * 0.114;
        if (lum < 80) {
          var newVal = Math.round(255 - (lum / 80) * 55);
          pixels[i] = newVal;
          pixels[i+1] = newVal;
          pixels[i+2] = newVal;
        }
      }

      var recolored = await sharp(pixels, {
        raw: { width: info.width, height: info.height, channels: ch }
      }).png().toBuffer();

      fs.writeFileSync(outputFile, recolored);
      console.log('  logo-dark.png created (' + info.width + 'x' + info.height + ')');
    })().catch(function(e) { console.error('  Error: ' + e.message); process.exit(1); });
  " "$OUTPUT_DIR/logo.png" "$OUTPUT_DIR/logo-dark.png" || echo "  Failed to create dark variant"

  # Also create logo-light.png (alias for the standard transparent logo)
  cp "$OUTPUT_DIR/logo.png" "$OUTPUT_DIR/logo-light.png"
  echo "  logo-light.png = logo.png (copy)"
fi

# Favicon — just the icon, no text
echo ""
echo "--- Step 1e: Generate favicon icon (Gemini, white bg) ---"

FAVICON_RAW="$OUTPUT_DIR/.favicon-raw.png"

FAVICON_PROMPT="The exact same geometric icon mark from the ${PRODUCT_NAME} logo. Just the icon, no text. Colors: ${PRIMARY_COLOR} and ${SECONDARY_COLOR}. Background: pure white (#FFFFFF). Square format, icon centered and filling most of the canvas. Simple geometric shape, professional SaaS style."

generate_gemini "$FAVICON_PROMPT" "$FAVICON_RAW" "$LOGO_RAW" || ((ERRORS++))

if [[ -f "$FAVICON_RAW" ]]; then
  recraft_remove_bg "$FAVICON_RAW" "$OUTPUT_DIR/favicon.png" || ((ERRORS++))
  if [[ -f "$OUTPUT_DIR/favicon.png" ]]; then
    trim_alpha "$OUTPUT_DIR/favicon.png" 3
    cp "$OUTPUT_DIR/favicon.png" "$OUTPUT_DIR/apple-touch-icon.png"
  fi
fi

# =============================================================================
# STEP 2: Product UI shots on WHITE bg → remove bg → trim
# =============================================================================

echo ""
echo "--- Step 2: Product UI shots (Gemini white bg + Recraft remove-bg + trim) ---"

BULLET_COUNT="$(node -e "process.stdout.write(String(Math.min(JSON.parse(process.argv[1]).length, 3)))" "$SOLUTION_BULLETS")"

if [[ "$BULLET_COUNT" -gt 0 ]]; then
  node -e "
    const bullets = JSON.parse(process.argv[1]);
    bullets.slice(0, 3).forEach((b, i) => {
      console.log(JSON.stringify({ index: i + 1, text: b }));
    });
  " "$SOLUTION_BULLETS" | while IFS= read -r bullet_json; do
    idx="$(node -e "process.stdout.write(String(JSON.parse(process.argv[1]).index))" "$bullet_json")"
    text="$(node -e "process.stdout.write(JSON.parse(process.argv[1]).text)" "$bullet_json")"

    RAW="$OUTPUT_DIR/.hero-${idx}-raw.png"

    SHOT_PROMPT="A screenshot of a single dark-themed UI panel for a SaaS product: ${text}.

The panel fills most of the image with minimal margins. It shows a dashboard element — charts, data, or controls relevant to the feature described. Dark panel background (${BG_COLOR}), accent highlights in ${PRIMARY_COLOR} and ${ACCENT_COLOR}. Rounded corners, subtle drop shadow. No logo or branding.

IMPORTANT: The panel must float on a PURE WHITE background (#FFFFFF). Nothing behind the panel except solid white. No gradient backgrounds, no dark areas outside the panel."

    echo ""
    generate_gemini "$SHOT_PROMPT" "$RAW" || { ((ERRORS++)); continue; }
    if [[ -f "$RAW" ]]; then
      recraft_remove_bg "$RAW" "$OUTPUT_DIR/hero-${idx}.png" || ((ERRORS++))
      [[ -f "$OUTPUT_DIR/hero-${idx}.png" ]] && trim_alpha "$OUTPUT_DIR/hero-${idx}.png" 1
    fi
  done
else
  echo "  No solution bullets — skipping"
fi

# =============================================================================
# STEP 3: Feature illustrations — SKIPPED (template uses built-in SVG icons)
# =============================================================================

echo ""
echo "--- Step 3: Feature illustrations — skipped (using SVG icons from config) ---"

# =============================================================================
# STEP 4: Hero background (dark, full-bleed — keep as-is, no trim)
# =============================================================================

echo ""
echo "--- Step 4: Hero background (Gemini, dark, kept as-is) ---"

generate_gemini "Abstract hero background image for a landing page. Dark background (${BG_COLOR}), with flowing abstract shapes and subtle glowing light trails in ${PRIMARY_COLOR} and ${SECONDARY_COLOR}. Ethereal, futuristic, premium feel. NO text, NO UI elements, NO devices — pure abstract art. Light moving through space. High-end SaaS aesthetic. 16:9 aspect ratio." "$OUTPUT_DIR/hero.png" || ((ERRORS++))

# =============================================================================
# STEP 5: Product mockup WITH the generated logo for consistency
# =============================================================================

echo ""
echo "--- Step 5: Product mockup with logo (Gemini, dark) ---"

MOCKUP_PROMPT="Create a photorealistic MacBook Pro mockup showing the ${PRODUCT_NAME} application.

The laptop screen must display a dark-themed SaaS dashboard (background ${BG_COLOR}) with:
- The attached logo visible in the top-left corner of the dashboard
- Data visualizations, charts, and metrics accented in ${PRIMARY_COLOR} and ${SECONDARY_COLOR}
- A clean, modern interface — think Linear or Vercel dashboard

The laptop should be slightly angled (3/4 perspective), floating with a subtle shadow. Very dark background with subtle ${PRIMARY_COLOR} gradient lighting. Professional product photography style. 4:3 composition — show the full laptop with comfortable margins on all sides.

CRITICAL: The logo shown on the laptop screen must match the attached logo image exactly. Do not invent a different logo."

LOGO_REF="$OUTPUT_DIR/logo.png"
[[ ! -f "$LOGO_REF" ]] && LOGO_REF="$LOGO_RAW"

MOCKUP_RAW="$OUTPUT_DIR/.mockup-raw.png"
generate_gemini "$MOCKUP_PROMPT" "$MOCKUP_RAW" "$LOGO_REF" || ((ERRORS++))

# Remove background to get transparent floating laptop
if [[ -f "$MOCKUP_RAW" ]]; then
  echo "  Removing mockup background..."
  recraft_remove_bg "$MOCKUP_RAW" "$OUTPUT_DIR/mockup.png" || {
    echo "  Warning: bg removal failed, using original"
    cp "$MOCKUP_RAW" "$OUTPUT_DIR/mockup.png"
    ((ERRORS++))
  }
  if [[ -f "$OUTPUT_DIR/mockup.png" ]]; then
    trim_alpha "$OUTPUT_DIR/mockup.png" 10
  fi
fi

# =============================================================================
# STEP 6: OG social card (dark, kept as-is)
# =============================================================================

echo ""
echo "--- Step 6: OG social card (Gemini, dark) ---"

generate_gemini "Social media preview card, 1200x630 pixels. Dark navy background (${BG_COLOR}). Large white bold text: ${PRODUCT_NAME}. Below in smaller gray text: ${HERO_HEADLINE}. Subtle geometric accents in ${PRIMARY_COLOR} and ${SECONDARY_COLOR}. No photos, no screenshots, no hex codes visible. Clean typographic design. Professional SaaS branding like Vercel or Linear." "$OUTPUT_DIR/og.png" || ((ERRORS++))

# =============================================================================
# Cleanup raw intermediates
# =============================================================================

rm -f "$OUTPUT_DIR"/.logo-raw.png "$OUTPUT_DIR"/.favicon-raw.png \
      "$OUTPUT_DIR"/.hero-*-raw.png "$OUTPUT_DIR"/.feature-*-raw.png \
      "$OUTPUT_DIR"/.mockup-raw.png

# =============================================================================
# Summary
# =============================================================================

echo ""
echo "=== Generation complete ==="
echo "Output: $OUTPUT_DIR"
ls -lh "$OUTPUT_DIR"/ 2>/dev/null | grep -v '^\.\|^total' || echo "  (no assets found)"

if [[ $ERRORS -gt 0 ]]; then
  echo ""
  echo "WARNING: $ERRORS asset(s) failed"
  exit 1
fi

echo ""
echo "All assets generated successfully."
